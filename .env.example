# Copy this file to .env or export these values in /etc/default/ac-remote.
# Do not commit real tokens, QQ numbers, campus credentials, or passwords.

AC_REMOTE_CONFIG=/home/orangepi/ac_remote_test/orange-pi/config.json

# Orange Pi Flask services
APP_HOST=0.0.0.0
APP_PORT=8081
QQ_BOT_HOST=0.0.0.0
QQ_BOT_PORT=8091

# NapCatQQ / OneBot11
NAPCAT_BASE_URL=http://<WINDOWS_HOST>:<NAPCAT_HTTP_PORT>
NAPCAT_ACCESS_TOKEN=<NAPCAT_TOKEN>
ONEBOT_POST_SECRET=<ONEBOT_POST_SECRET>
BOT_QQ=<BOT_QQ>

# ESP8266 IR gateway
ESP8266_BASE_URL=http://<ESP8266_IP>
ESP8266_TIMEOUT_SECONDS=5

# Orange Pi hotspot
AP_IFACE=ap0
AP_PHY_IFACE=wlan0
AP_SSID=AC_Remote_AP
AP_PASSWORD=<HOTSPOT_PASSWORD>
AP_CIDR=192.168.10.1/24
AP_DHCP_RANGE_START=192.168.10.50
AP_DHCP_RANGE_END=192.168.10.150

# Optional campus electricity query integration.
# Keep these placeholders until you implement your own adapter.
ELECTRICITY_API_URL=<CAMPUS_ELECTRICITY_API_URL>
CAMPUS_ACCOUNT=<CAMPUS_ACCOUNT>
CAMPUS_PASSWORD=<CAMPUS_PASSWORD>

