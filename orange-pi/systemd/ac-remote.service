[Unit]
Description=Orange Pi AC Remote Flask Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=orangepi
Group=orangepi
WorkingDirectory=/home/orangepi/ac_remote_test/orange-pi
EnvironmentFile=-/etc/default/ac-remote
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/orangepi/ac_remote_test/.venv/bin/python /home/orangepi/ac_remote_test/orange-pi/app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target

